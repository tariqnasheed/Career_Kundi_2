# ─────────────────────────────────────────────────────────
# CareerKundi Backend — Environment Variables
# Copy this file to `.env` and fill in real values.
# Every variable below maps EXACTLY to a field on the Pydantic
# `Settings` class in app/core/config.py (that class is the single
# source of truth). The platform runs fully with mock LLM/search —
# no API keys are required for local development.
# ─────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────
APP_ENV=development                      # development | staging | production
APP_NAME=careerkundi-backend
APP_VERSION=0.1.0
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=change-me-generate-with-openssl-rand-hex-32   # openssl rand -hex 32

# ── LLM (Gemini) ─────────────────────────────────────────
# Leave GEMINI_API_KEY blank to run in deterministic mock mode (zero cost).
# There is NO "LLM_MODE" variable — the mode is derived automatically from
# whether GEMINI_API_KEY is set (see Settings.llm_mode).
GEMINI_API_KEY=
GEMINI_MODEL_FLASH=gemini-2.5-flash      # cheap/fast tier (routine + validation)
GEMINI_MODEL_PRO=gemini-2.5-pro          # deep tier (complex generation)
GEMINI_EMBEDDING_MODEL=text-embedding-004

# ── Search grounding (SerpAPI) ───────────────────────────
# Leave blank to fall back to the mock search provider. As with the LLM,
# there is NO "SEARCH_MODE" variable — it is derived from SERPAPI_KEY.
SERPAPI_KEY=

# ── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://careerkundi:careerkundi@localhost:5432/careerkundi        # async (app)
DATABASE_URL_SYNC=postgresql+psycopg2://careerkundi:careerkundi@localhost:5432/careerkundi  # sync (Alembic)

# ── Cache ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Vector store (RAG) / Knowledge graph (GraphRAG) ──────
VECTOR_STORE_URL=                        # blank -> backend/data/vector_store
VECTOR_STORE_PROVIDER=faiss              # faiss | pinecone | weaviate
GRAPH_STORE_PATH=                        # blank -> backend/data/knowledge_graph.gpickle

# ── Auth (JWT) ───────────────────────────────────────────
JWT_SECRET=change-me-too-please-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ─────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Web scraping ─────────────────────────────────────────
PLAYWRIGHT_BROWSER=chromium              # chromium | firefox | webkit
SCRAPER_USER_AGENT=CareerkundiBot/1.0 (+https://careerkundi.com/bot)
SCRAPER_TIMEOUT_MS=15000
SCRAPER_MAX_CONCURRENCY=4

# ── Rate limiting ────────────────────────────────────────
RATE_LIMIT_UNAUTHENTICATED=30/minute
RATE_LIMIT_AUTHENTICATED=120/minute
RATE_LIMIT_LLM_HEAVY=10/minute

# ── Cost controls ────────────────────────────────────────
TOKEN_BUDGET_PER_REQUEST=200000
PROMPT_CACHE_TTL_SECONDS=86400

# ── Observability ────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=             # blank disables tracing export
LOG_LEVEL=INFO                           # DEBUG | INFO | WARNING | ERROR | CRITICAL
