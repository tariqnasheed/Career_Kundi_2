# Development variant — installs dev dependencies and runs with --reload.
# Used by docker-compose.dev.yml for volume-mounted, hot-reloading local dev.
FROM python:3.11-slim
COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv
WORKDIR /app
COPY pyproject.toml ./
RUN uv venv .venv && uv pip install --python .venv/bin/python -e ".[dev]" --no-cache
ENV PATH="/app/.venv/bin:$PATH" PYTHONUNBUFFERED=1
COPY . .
EXPOSE 8000
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]
