# =============================================================================
# Careerkundi — .gitignore
# Every entry below is commented so future contributors know WHY it's excluded.
# =============================================================================

# --- Python ------------------------------------------------------------------
# Compiled bytecode caches, regenerated on every run
__pycache__/
# Compiled/optimized Python files (.pyc/.pyo/.pyd)
*.py[cod]
# Jython compiled classes (defensive, unused here)
*$py.class
# Compiled C extensions (faiss/native deps build artifacts)
*.so
# Local virtualenv created by `uv sync`
.venv/
venv/
env/
# setuptools metadata generated on install
*.egg-info/
*.egg
.eggs/

# --- UV --------------------------------------------------------------------
# UV's local cache directory
.uv/

# --- Node.js -----------------------------------------------------------------
# Installed npm packages — restored via `npm install`
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- Build outputs -------------------------------------------------------------
# Frontend production build output (Vite)
frontend/dist/
# Generic build output directory
build/
# (unused here, defensive for future Next.js migration)
.next/
out/
# Vite hot-reload artifacts — regenerated on every dev start
*.timestamp-*.mjs

# --- Environment files (NEVER commit secrets) ------------------------------------
# Real secrets — local backend env file
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production
# Exception: the documented template IS committed
!.env.example

# --- IDE -------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath

# --- OS --------------------------------------------------------------------------
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# --- Docker ------------------------------------------------------------------------
# Local-only compose overrides should never be shared
docker-compose.override.yml

# --- Database ----------------------------------------------------------------------
*.db
*.sqlite3
# Local Postgres volume data (if bind-mounted)
data/postgres/
# Local Redis volume data (if bind-mounted)
data/redis/
# Generated FAISS index — rebuildable from source data
data/vector_store/
# Generated knowledge graph — rebuildable
data/knowledge_graph.gpickle

# --- Logs -----------------------------------------------------------------------------
*.log
logs/

# --- Testing & Coverage -----------------------------------------------------------------
.coverage
htmlcov/
coverage/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Playwright -------------------------------------------------------------------------
/test-results/
/playwright-report/
/playwright/.cache/

# --- Generated user files -----------------------------------------------------------------
*.pdf
*.docx
uploads/
generated/
__pycache__/
*.py[cod]

# Vite / Vitest local caches
frontend/node_modules/.vite/
