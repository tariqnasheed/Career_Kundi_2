# =============================================================================
# Careerkundi — Environment Variable Reference
# =============================================================================
# Copy this file to `.env` (backend) — `cp .env.example .env` — and fill in
# real values. Never commit the real `.env` file; it is excluded in .gitignore.
# Every variable below is read by backend/app/core/config.py via Pydantic
# Settings, which validates types and provides safe defaults for local dev.
# =============================================================================

# --- Application -------------------------------------------------------------
APP_ENV=development                      # development | staging | production
APP_NAME=careerkundi-backend
APP_VERSION=0.1.0
APP_DEBUG=true                           # Enables verbose logging + auto-reload
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=change-me-to-a-random-64-char-string   # Used for misc HMAC signing

# --- LLM Providers -------------------------------------------------------------
# Gemini is the primary LLM backbone for every agent (interview packs, CVs,
# roadmaps, chat). If GEMINI_API_KEY is left blank, the system automatically
# falls back to the deterministic MockGeminiProvider (see app/tools/llm.py)
# so the whole platform remains fully runnable and demoable with zero cost.
GEMINI_API_KEY=                          # Get one at https://aistudio.google.com/app/apikey
GEMINI_MODEL_FLASH=gemini-2.5-flash      # Cheap/fast tier — routine + validation tasks
GEMINI_MODEL_PRO=gemini-2.5-pro          # Expensive/deep tier — complex generation tasks
GEMINI_EMBEDDING_MODEL=text-embedding-004 # Embedding model for RAG vector store

# Google Search grounding (via SerpAPI) — used by the Reflector agents to
# independently re-verify every factual claim before it reaches the user.
# Leave blank to fall back to the local MockSearchProvider (canned, clearly
# labeled "unverified" results) so grounding logic still runs end-to-end.
SERPAPI_KEY=                             # Get one at https://serpapi.com

# --- Database ------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://careerkundi:careerkundi@db:5432/careerkundi
DATABASE_URL_SYNC=postgresql+psycopg2://careerkundi:careerkundi@db:5432/careerkundi  # used by Alembic
POSTGRES_USER=careerkundi
POSTGRES_PASSWORD=careerkundi
POSTGRES_DB=careerkundi

# --- Cache / Queue ---------------------------------------------------------------
REDIS_URL=redis://redis:6379/0           # Prompt cache, rate limiter, session store

# --- Vector store (RAG) -----------------------------------------------------------
VECTOR_STORE_URL=./data/vector_store     # Local FAISS index directory (file-based, no server needed)
VECTOR_STORE_PROVIDER=faiss              # faiss (local) | pinecone | weaviate (future)

# --- Knowledge graph (GraphRAG) ---------------------------------------------------
GRAPH_STORE_PATH=./data/knowledge_graph.gpickle  # networkx graph persisted to disk

# --- Auth ------------------------------------------------------------------------
JWT_SECRET=change-me-too-please-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- CORS ------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://careerkundi.com

# --- Web scraping ------------------------------------------------------------------
PLAYWRIGHT_BROWSER=chromium              # chromium | firefox | webkit
SCRAPER_USER_AGENT=CareerkundiBot/1.0 (+https://careerkundi.com/bot)
SCRAPER_TIMEOUT_MS=15000
SCRAPER_MAX_CONCURRENCY=4

# --- Rate limiting -----------------------------------------------------------------
RATE_LIMIT_UNAUTHENTICATED=30/minute
RATE_LIMIT_AUTHENTICATED=120/minute
RATE_LIMIT_LLM_HEAVY=10/minute

# --- Cost controls ------------------------------------------------------------------
TOKEN_BUDGET_PER_REQUEST=200000          # Soft ceiling enforced by CostMonitorAgent
PROMPT_CACHE_TTL_SECONDS=86400           # 24h cache for identical/similar prompts

# --- Observability -----------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=             # Leave blank to disable tracing export locally
LOG_LEVEL=INFO                           # DEBUG | INFO | WARNING | ERROR | CRITICAL

# --- Job search study synthesis -----------------------------------------------
# Model-knowledge study synthesis is disabled by default (no API calls).
JOB_SEARCH_ENABLE_MODEL_KNOWLEDGE=false
JOB_SEARCH_MODEL_KNOWLEDGE_PROVIDER=disabled   # disabled | deterministic_test | gemini

# --- Frontend (read by frontend/.env via Vite) ---------------------------------------
VITE_API_BASE_URL=http://localhost:8000
VITE_APP_NAME=Careerkundi
